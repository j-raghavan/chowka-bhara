# Public, non-secret transport configuration only. NEVER put admin/service-role keys here.
# GitHub Pages base path for production builds, e.g. /chowka-bhara-online/
VITE_BASE=/

# Transport selection: "memory" (default, local only) | "firebase" | "supabase"
VITE_TRANSPORT=memory

# Firebase (public web config only — these are not secrets, but Firestore security rules ARE required)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=

# Supabase (anon public key only)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
